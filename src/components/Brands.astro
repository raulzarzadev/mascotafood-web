---
import { BRANDS, BRAND_CATEGORIES, SMALL_PETS, SITE } from '../consts';

type CategoryKey = keyof typeof BRAND_CATEGORIES;

const grouped: Record<CategoryKey, typeof BRANDS[number][]> = {
  perros: [],
  gatos: [],
  arena: [],
};
for (const b of BRANDS) grouped[b.category as CategoryKey].push(b);

const iconPath: Record<string, string> = {
  dog: 'M4.5 12.5C3 11 3 9 4 8s3-1 4 .5M19.5 12.5C21 11 21 9 20 8s-3-1-4 .5M8 8.5c0-1 .5-2 2-2s2 1 2 2M12 8.5c0-1 .5-2 2-2s2 1 2 2M7 13c-1 2-1 4 1 5.5S11 20 12 20s3 0 4-1.5 2-3.5 1-5.5M12 14v3',
  cat: 'M5 8 3 4l3 2h12l3-2-2 4M7 8h10a3 3 0 0 1 3 3v6a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3v-6a3 3 0 0 1 3-3zM10 14h.01M14 14h.01M12 18v-1',
  paw: 'M11 14c.7 0 1.2-.6 1.2-1.3 0-.7-.5-1.3-1.2-1.3s-1.2.6-1.2 1.3c0 .7.5 1.3 1.2 1.3zM7 11c.7 0 1.2-.6 1.2-1.3C8.2 9 7.7 8.4 7 8.4s-1.2.6-1.2 1.3c0 .7.5 1.3 1.2 1.3zM15 11c.7 0 1.2-.6 1.2-1.3 0-.7-.5-1.3-1.2-1.3s-1.2.6-1.2 1.3c0 .7.5 1.3 1.2 1.3zM19 14c.7 0 1.2-.6 1.2-1.3 0-.7-.5-1.3-1.2-1.3s-1.2.6-1.2 1.3c0 .7.5 1.3 1.2 1.3zM11 16c-2.5 0-5 1-5 3 0 2 2 3 5 3s5-1 5-3c0-2-2.5-3-5-3z',
};

const order: CategoryKey[] = ['perros', 'gatos', 'arena'];
---

<section id="marcas" class="bg-white py-20 sm:py-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Marcas que manejamos</span>
      <h2 class="mt-2 text-3xl font-extrabold tracking-tight text-stone-900 sm:text-4xl">
        Las marcas favoritas de tu mascota, aquí
      </h2>
      <p class="mt-4 text-stone-600">
        Manejamos las principales marcas <strong>premium</strong> nacionales e importadas para perros y gatos. Si buscas una en específico y no la ves, pregúntanos: muchas veces la conseguimos bajo pedido.
      </p>
    </div>

    <div class="mt-14 space-y-10">
      {order.filter((cat) => grouped[cat].length > 0).map((cat) => {
        const meta = BRAND_CATEGORIES[cat];
        const brands = grouped[cat];
        return (
          <div>
            <div class="flex items-center gap-3">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-100 text-brand-700">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={iconPath[meta.icon]} />
                </svg>
              </span>
              <h3 class="text-xl font-bold text-stone-900">{meta.label}</h3>
              <span class="text-sm text-stone-500">({brands.length})</span>
            </div>
            <ul class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
              {brands.map((brand) => (
                <li>
                  <a
                    href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(`Hola! ¿Tienen ${brand.name} en existencia?`)}`}
                    target="_blank"
                    rel="noopener"
                    class="group flex h-full flex-col rounded-xl border border-stone-200 bg-stone-50 p-4 transition hover:-translate-y-0.5 hover:border-brand-300 hover:bg-white hover:shadow-md"
                    aria-label={`Consultar disponibilidad de ${brand.name} por WhatsApp`}
                  >
                    <span class="font-bold text-stone-900 group-hover:text-brand-700">{brand.name}</span>
                    <span class="mt-1 text-xs text-stone-500 group-hover:text-stone-700">{brand.tagline}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl bg-accent-500/5 p-5 ring-1 ring-accent-500/20">
        <h3 class="flex items-center gap-2 font-bold text-accent-700">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2a10 10 0 1 0 10 10"/>
            <path d="M12 6v6l4 2"/>
          </svg>
          También para mascotas pequeñas
        </h3>
        <ul class="mt-3 flex flex-wrap gap-2">
          {SMALL_PETS.map((p) => (
            <li class="inline-flex items-center gap-1 rounded-full bg-white px-3 py-1 text-sm text-stone-700 ring-1 ring-accent-500/30">{p}</li>
          ))}
        </ul>
      </div>

      <div class="rounded-xl bg-brand-50 p-5 ring-1 ring-brand-100">
        <h3 class="flex items-center gap-2 font-bold text-brand-700">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2v20M2 12h20"/>
          </svg>
          ¿Buscas otra marca?
        </h3>
        <p class="mt-3 text-sm text-stone-700">
          Si no ves tu marca favorita, <strong>consúltanos por WhatsApp</strong>. Conseguimos muchas más sobre pedido, especialmente Royal Canin y Hill's en presentaciones específicas.
        </p>
      </div>
    </div>
  </div>
</section>
