---
const features = [
  {
    title: 'Envío a domicilio gratis',
    description: 'Recibe tus productos sin costo adicional dentro de nuestra zona de cobertura.',
    icon: 'truck',
  },
  {
    title: 'Productos premium',
    description: 'Marcas nacionales e importadas seleccionadas para la salud de tu mascota.',
    icon: 'award',
  },
  {
    title: 'Asesoría personalizada',
    description: 'Te ayudamos a elegir el alimento ideal según raza, edad y necesidades.',
    icon: 'chat',
  },
  {
    title: 'Pago seguro',
    description: 'Tarjeta, transferencia o efectivo, como más te convenga.',
    icon: 'shield',
  },
] as const;

const icons = {
  truck: 'M3 7h11v9H3zM14 10h4l3 3v3h-7zM6 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm12 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4z',
  award: 'M12 15a5 5 0 1 0 0-10 5 5 0 0 0 0 10zm-3 0-1.5 6 4.5-3 4.5 3L15 15',
  chat: 'M21 12a8 8 0 1 1-3.5-6.6L21 4l-1 4.5A8 8 0 0 1 21 12zM8 12h.01M12 12h.01M16 12h.01',
  shield: 'M12 2 4 5v7c0 5 3.5 8.5 8 10 4.5-1.5 8-5 8-10V5l-8-3z',
};
---

<section class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-6 sm:gap-8 lg:grid-cols-4">
      {features.map((f) => (
        <div class="group rounded-2xl border border-stone-200 bg-stone-50 p-5 transition hover:-translate-y-1 hover:border-brand-300 hover:bg-white hover:shadow-xl">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand-100 text-brand-700 transition group-hover:bg-brand-600 group-hover:text-white">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={icons[f.icon]} />
            </svg>
          </div>
          <h3 class="font-bold text-stone-900">{f.title}</h3>
          <p class="mt-1 text-sm text-stone-600">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
