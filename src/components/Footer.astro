---
import { SITE, NAV_LINKS } from '../consts';

const year = new Date().getFullYear();
---

<footer class="bg-stone-900 text-stone-300">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 py-12 sm:px-6 lg:grid-cols-4 lg:px-8">
    <div class="lg:col-span-2">
      <div class="flex items-center gap-3">
        <img
          src="/icons/LogoMascotaFoodSigno.gif"
          alt="Mascota Food logotipo"
          width="48"
          height="48"
          class="h-12 w-12 rounded-full bg-white p-1"
          loading="lazy"
          decoding="async"
        />
        <span class="text-2xl font-bold text-white">{SITE.name}</span>
      </div>
      <p class="mt-1 text-sm font-medium text-brand-400">
        Mascota Food Villas · Atizapán de Zaragoza
      </p>
      <p class="mt-3 max-w-md text-sm text-stone-400">
        {SITE.description}
      </p>

      <div class="mt-6 flex gap-3">
        <a
          href={SITE.social.facebook}
          target="_blank"
          rel="noopener"
          class="flex h-10 w-10 items-center justify-center rounded-full bg-stone-800 transition hover:bg-brand-600"
          aria-label="Facebook"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M9.2 22v-8H6v-4h3.2V7.5c0-3.2 1.9-5 4.8-5 1.4 0 2.9.3 2.9.3V6h-1.6c-1.6 0-2.1 1-2.1 2v2.4h3.6l-.6 4h-3V22z"/>
          </svg>
        </a>
        <a
          href={SITE.social.instagram}
          target="_blank"
          rel="noopener"
          class="flex h-10 w-10 items-center justify-center rounded-full bg-stone-800 transition hover:bg-brand-600"
          aria-label="Instagram"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.2c3.2 0 3.6 0 4.8.1 1.2.1 1.8.2 2.3.4.6.2 1 .5 1.5 1 .5.5.8.9 1 1.5.2.4.3 1.1.4 2.3 0 1.2.1 1.6.1 4.8s0 3.6-.1 4.8c-.1 1.2-.2 1.8-.4 2.3a4 4 0 0 1-1 1.5c-.5.5-.9.8-1.5 1-.4.2-1.1.3-2.3.4-1.2 0-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2-.1-1.8-.2-2.3-.4a4 4 0 0 1-1.5-1 4 4 0 0 1-1-1.5c-.2-.4-.3-1.1-.4-2.3 0-1.2-.1-1.6-.1-4.8s0-3.6.1-4.8c.1-1.2.2-1.8.4-2.3.2-.6.5-1 1-1.5s.9-.8 1.5-1c.4-.2 1.1-.3 2.3-.4 1.2 0 1.6-.1 4.8-.1zm0 6.3a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7zm5.4-.6a.8.8 0 1 0 0-1.6.8.8 0 0 0 0 1.6zM12 10a2 2 0 1 1 0 4 2 2 0 0 1 0-4z"/>
          </svg>
        </a>
        <a
          href={`https://wa.me/${SITE.whatsapp}`}
          target="_blank"
          rel="noopener"
          class="flex h-10 w-10 items-center justify-center rounded-full bg-stone-800 transition hover:bg-brand-600"
          aria-label="WhatsApp"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.5 3.5A11.8 11.8 0 0 0 12 0C5.5 0 .2 5.3.2 11.8c0 2.1.6 4.1 1.6 5.9L0 24l6.4-1.7a11.8 11.8 0 0 0 5.7 1.5c6.5 0 11.8-5.3 11.8-11.8 0-3.2-1.2-6.2-3.4-8.5Z"/>
          </svg>
        </a>
      </div>
    </div>

    <div>
      <h3 class="font-bold text-white">Navegación</h3>
      <ul class="mt-4 space-y-2 text-sm">
        {NAV_LINKS.map((link) => (
          <li>
            <a href={link.href} class="transition hover:text-brand-400">{link.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="font-bold text-white">Contacto</h3>
      <ul class="mt-4 space-y-2 text-sm">
        <li>
          <a href={`tel:${SITE.phone}`} class="transition hover:text-brand-400">
            {SITE.phoneDisplay}
          </a>
        </li>
        <li>
          <a href={`mailto:${SITE.email}`} class="transition hover:text-brand-400">
            {SITE.email}
          </a>
        </li>
        <li>
          <a href={SITE.maps.url} target="_blank" rel="noopener" class="text-stone-400 transition hover:text-brand-400">
            {SITE.address.streetAddress},<br />
            {SITE.address.postalCode} {SITE.address.locality}, {SITE.address.region}
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-stone-800">
    <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-3 px-4 py-6 text-xs text-stone-500 sm:flex-row sm:px-6 lg:px-8">
      <p>© {year} {SITE.name}. Todos los derechos reservados.</p>
      <nav aria-label="Legal" class="flex flex-wrap items-center gap-4">
        <a href="/privacidad" class="transition hover:text-brand-400">Aviso de Privacidad</a>
        <a href="/devoluciones" class="transition hover:text-brand-400">Cambios y devoluciones</a>
      </nav>
    </div>
  </div>
</footer>
