---
import { SITE, NAV_LINKS } from '../consts';
---

<header class="sticky top-0 z-40 border-b border-brand-100 bg-white/80 backdrop-blur-md">
  <nav
    class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-4 py-3 sm:px-6 lg:px-8"
    aria-label="Navegación principal"
  >
    <a href="#inicio" class="flex items-center gap-2 font-bold text-brand-700" aria-label={`Inicio - ${SITE.name}`}>
      <img
        src="/icons/LogoMascotaFoodSigno.gif"
        alt=""
        width="40"
        height="40"
        class="h-10 w-10 rounded-full"
        loading="eager"
        decoding="async"
      />
      <span class="text-lg sm:text-xl">{SITE.name}</span>
    </a>

    <ul class="hidden items-center gap-6 md:flex">
      {NAV_LINKS.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm font-medium text-stone-700 transition hover:text-brand-600 focus-visible:text-brand-600"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a
      href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent('Hola! Me gustaría saber más sobre sus productos.')}`}
      target="_blank"
      rel="noopener"
      class="hidden items-center gap-2 rounded-full bg-brand-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-700 sm:inline-flex"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M20.52 3.48A11.78 11.78 0 0 0 12.07 0C5.55 0 .24 5.3.24 11.83a11.7 11.7 0 0 0 1.6 5.94L0 24l6.4-1.67a11.79 11.79 0 0 0 5.66 1.44h.01c6.52 0 11.83-5.3 11.83-11.83 0-3.16-1.23-6.13-3.38-8.36ZM12.07 21.72h-.01a9.86 9.86 0 0 1-5.02-1.38l-.36-.21-3.8 1 1.02-3.71-.23-.38a9.84 9.84 0 0 1-1.5-5.21c0-5.44 4.43-9.86 9.89-9.86 2.64 0 5.13 1.03 7 2.9a9.8 9.8 0 0 1 2.9 7c0 5.44-4.43 9.85-9.89 9.85Zm5.41-7.37c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07a8.11 8.11 0 0 1-2.39-1.47 9 9 0 0 1-1.66-2.07c-.17-.3-.02-.46.13-.61.13-.13.3-.35.44-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.48-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.04 1.02-1.04 2.49 0 1.47 1.07 2.89 1.22 3.09.15.2 2.1 3.2 5.08 4.49.71.3 1.26.48 1.69.62.71.23 1.35.2 1.86.12.57-.08 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.07-.12-.27-.2-.57-.35Z"/>
      </svg>
      WhatsApp
    </a>
  </nav>
</header>
