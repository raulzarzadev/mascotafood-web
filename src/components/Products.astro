---
import { PRODUCTS, SITE } from '../consts';
---

<section id="productos" class="bg-stone-50 py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Nuestros productos</span>
      <h2 class="mt-2 text-3xl font-extrabold tracking-tight text-stone-900 sm:text-4xl">
        Variedad de alimentos, marcas y presentaciones
      </h2>
      <p class="mt-4 text-stone-600">
        Todo lo que tu perro o gato necesita para una vida feliz y saludable, seleccionado con el cuidado de quien también tiene mascota.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {PRODUCTS.map((product, idx) => (
        <article class="group relative overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-stone-200 transition hover:-translate-y-1 hover:shadow-xl">
          <div class="relative h-48 overflow-hidden bg-stone-100">
            <img
              src={product.image}
              alt={product.title}
              class="h-full w-full object-cover transition duration-500 group-hover:scale-110"
              width="400"
              height="300"
              loading={idx < 4 ? 'eager' : 'lazy'}
              decoding="async"
            />
            {product.badge && (
              <span class="absolute left-3 top-3 rounded-full bg-brand-600 px-3 py-1 text-xs font-semibold text-white shadow-md">
                {product.badge}
              </span>
            )}
          </div>
          <div class="p-5">
            <h3 class="font-bold text-stone-900">{product.title}</h3>
            <p class="mt-2 text-sm text-stone-600">{product.description}</p>
            <a
              href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(`Hola! Me interesa: ${product.title}`)}`}
              target="_blank"
              rel="noopener"
              class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-700 transition hover:gap-2 hover:text-brand-800"
              aria-label={`Consultar sobre ${product.title} por WhatsApp`}
            >
              Consultar
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
