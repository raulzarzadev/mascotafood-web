---
import { FAQS } from '../consts';

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQS.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a },
  })),
};
---

<section id="faq" class="bg-stone-50 py-20 sm:py-24">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Preguntas frecuentes</span>
      <h2 class="mt-2 text-3xl font-extrabold tracking-tight text-stone-900 sm:text-4xl">
        Resolvemos tus dudas
      </h2>
    </div>

    <div class="mt-12 space-y-3">
      {FAQS.map((faq, idx) => (
        <details class="group rounded-xl border border-stone-200 bg-white p-5 transition hover:border-brand-300" open={idx === 0}>
          <summary class="flex cursor-pointer items-center justify-between gap-4 font-semibold text-stone-900 marker:hidden list-none">
            <span>{faq.q}</span>
            <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand-100 text-brand-700 transition group-open:rotate-45">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                <path d="M12 5v14M5 12h14" />
              </svg>
            </span>
          </summary>
          <p class="mt-3 text-stone-600">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>

  <script
    type="application/ld+json"
    set:html={JSON.stringify(faqJsonLd)}
  />
</section>
