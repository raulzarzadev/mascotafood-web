---
import { SITE } from '../consts';
---

<section id="contacto" class="relative overflow-hidden bg-gradient-to-br from-brand-600 to-brand-800 py-20 text-white sm:py-24">
  <div class="absolute inset-0 opacity-10" aria-hidden="true">
    <div class="absolute -top-24 -left-24 h-96 w-96 rounded-full bg-white blur-3xl"></div>
    <div class="absolute -bottom-24 -right-24 h-96 w-96 rounded-full bg-accent-500 blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="text-3xl font-extrabold tracking-tight sm:text-4xl">
      ¿Listo para consentir a tu mascota?
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-brand-50">
      Escríbenos por WhatsApp y recibe asesoría personalizada. Hacemos entregas a domicilio gratis en nuestra zona.
    </p>

    <div class="mt-10 grid gap-4 sm:grid-cols-3">
      <a
        href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent('Hola! Quisiera hacer un pedido.')}`}
        target="_blank"
        rel="noopener"
        class="group rounded-2xl bg-white/10 p-6 backdrop-blur transition hover:bg-white/20"
      >
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-xl bg-white text-brand-700">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.52 3.48A11.78 11.78 0 0 0 12.07 0C5.55 0 .24 5.3.24 11.83a11.7 11.7 0 0 0 1.6 5.94L0 24l6.4-1.67a11.79 11.79 0 0 0 5.66 1.44c6.52 0 11.83-5.3 11.83-11.83 0-3.16-1.23-6.13-3.41-8.36Z"/>
          </svg>
        </div>
        <h3 class="mt-4 font-bold">WhatsApp</h3>
        <p class="mt-1 text-sm text-brand-50">{SITE.phoneDisplay}</p>
      </a>

      <a
        href={`tel:${SITE.phone}`}
        class="group rounded-2xl bg-white/10 p-6 backdrop-blur transition hover:bg-white/20"
      >
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-xl bg-white text-brand-700">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92V21a1 1 0 0 1-1.11 1 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 3.18 4.11 1 1 0 0 1 4.18 3h4.09a1 1 0 0 1 1 .75l.94 3.13a1 1 0 0 1-.25 1L8.31 9.57a16 16 0 0 0 6 6l1.71-1.64a1 1 0 0 1 1-.25l3.13.94a1 1 0 0 1 .85 1.3Z"/>
          </svg>
        </div>
        <h3 class="mt-4 font-bold">Teléfono</h3>
        <p class="mt-1 text-sm text-brand-50">{SITE.phoneDisplay}</p>
      </a>

      <a
        href={`mailto:${SITE.email}`}
        class="group rounded-2xl bg-white/10 p-6 backdrop-blur transition hover:bg-white/20"
      >
        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-xl bg-white text-brand-700">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <path d="m22 6-10 7L2 6"/>
          </svg>
        </div>
        <h3 class="mt-4 font-bold">Correo</h3>
        <p class="mt-1 break-all text-sm text-brand-50">{SITE.email}</p>
      </a>
    </div>
  </div>
</section>
